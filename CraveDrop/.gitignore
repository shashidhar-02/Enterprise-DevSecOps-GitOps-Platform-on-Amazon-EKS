# ==============================================================
# CraveDrop - Root .gitignore
# ==============================================================

# Node dependencies & logs
node_modules/
npm-debug.log
*.log

# Build outputs (Frontend & Backend)
dist/
build/

# Environment variables (Security: NEVER commit these)
.env
.env.*
.env.local

# Terraform (DevSecOps Infrastructure)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl
terraform/crash.log

# Docker
*.tar

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db