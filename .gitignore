# ==============================================================
# CraveDrop Full-Stack & Infrastructure .gitignore
# ==============================================================

# ---- Node.js / Frontend / Backend ----
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
coverage/

# ---- Security & Secrets ----
# Never commit environment variables or Terraform variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.tfvars
*.tfvars.json
# Allow example files so the team knows what variables are needed
!*.example.tfvars

# ---- Terraform ----
# Local state and plugin directories
.terraform/
terraform.tfstate
terraform.tfstate.backup
crash.log
crash.*.log
# Note: .terraform.lock.hcl IS purposely NOT ignored here.

# ---- Docker ----
*.tar
*.tar.gz
*.image

# ---- IDEs & OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.swp